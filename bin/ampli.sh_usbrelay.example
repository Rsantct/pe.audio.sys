#!/bin/bash

# (i)   This amplifier switch is based on the 'usbrelay' binary,
#       which manages a simple HID usb relay unit.
#       Recently Debian offers the packet 'usbrelay'.
#       If not available, you can compile it by using the 'hidraw' library:
#           https://github.com/darrylb123/usbrelay
#       (It is needed to reboot the machine to usbrelay to work)
#
#       The 'usbrelay' executable:
#       - w/o args will show the state (0 or 1) of the relays
#       - passing arg 'BITFT_N=X' will switch a relay N to new state 0 or 1
#       (!) - the old relay status is writen to stderr,
#           - additional info is written to stdout

# CONFIGURE YOUR RELAY HERE:
myRelay="BITFT_1"

# current state
curr=$(usbrelay | awk -v r="$myRelay" -F'=' '$1 == r {print $2}')

# Switching:
if [[ $1 == '1' || $1 == 'on' || $1 == 'ON' ]]; then
    arg="$myRelay""=1"

elif [[ $1 == '0' || $1 == 'off' || $1 == 'OFF' ]]; then
    arg="$myRelay""=0"

elif [[ $1 == 'toggle' ]]; then

    if [[ $curr == '0' ]]; then
        arg="$myRelay""=1"
    else
        arg="$myRelay""=0"
    fi

else
    echo $curr
    exit 0
fi

# ordering
usbrelay "$arg"

# new state
new=$(usbrelay | awk -v r="$myRelay" -F'=' '$1 == r {print $2}')

# saving state to ~/.amplifier
echo $new > "$HOME"/.amplifier

# print out
cat "$HOME"/.amplifier
